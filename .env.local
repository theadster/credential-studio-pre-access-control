# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CO_DEV_ENV=development

# Email Verification Configuration
# URL where users will be redirected to complete email verification
# This should point to your verification page endpoint
NEXT_PUBLIC_VERIFICATION_URL=http://localhost:3000/verify-email

# Password Reset Configuration
# URL where users will be redirected to reset their password
# This should point to your password reset page endpoint
NEXT_PUBLIC_PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Appwrite Configuration
# Get these from your Appwrite project at https://cloud.appwrite.io
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=68daa3cd001938dc73a4
APPWRITE_API_KEY=standard_e600b72f23d61bcefbccbb64dd672b2d81dec6c369bf320a3cf598d21f799c8e9b45c77b820012f3f017380b9bd994e6e04f0dd06b5e623c182cfb398ce3142a71c0e2d7304fa81bec1546c17312173eaea60b4fff1520cc3322ad8e1185ee7e759ed87bd07bf404ce97c4814fb1435e26fbaab8abb6cfad3d9d373b9de635d8

# Session Cookie Configuration (optional)
# Name of the session cookie used for web client authentication
# Default: 'appwrite-session'
# APPWRITE_SESSION_COOKIE_NAME=appwrite-session

# Appwrite Database IDs (generated by setup-appwrite.ts script)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=credentialstudio
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION_ID=users
NEXT_PUBLIC_APPWRITE_ROLES_COLLECTION_ID=roles
NEXT_PUBLIC_APPWRITE_ATTENDEES_COLLECTION_ID=attendees
NEXT_PUBLIC_APPWRITE_CUSTOM_FIELDS_COLLECTION_ID=custom_fields
NEXT_PUBLIC_APPWRITE_EVENT_SETTINGS_COLLECTION_ID=event_settings
NEXT_PUBLIC_APPWRITE_LOGS_COLLECTION_ID=logs
NEXT_PUBLIC_APPWRITE_LOG_SETTINGS_COLLECTION_ID=log_settings
NEXT_PUBLIC_APPWRITE_ACCESS_CONTROL_COLLECTION_ID=access_control
NEXT_PUBLIC_APPWRITE_APPROVAL_PROFILES_COLLECTION_ID=approval_profiles
NEXT_PUBLIC_APPWRITE_SCAN_LOGS_COLLECTION_ID=scan_logs

# Access Control Feature Flag
# Set to 'true' to enable the Access Control feature globally
# When disabled, the Access Control tab and all related functionality will be hidden
# Default: false (disabled)
NEXT_PUBLIC_ENABLE_ACCESS_CONTROL=true

# Integration Collections
NEXT_PUBLIC_APPWRITE_CLOUDINARY_COLLECTION_ID=cloudinary_integrations
NEXT_PUBLIC_APPWRITE_SWITCHBOARD_COLLECTION_ID=switchboard_integrations
NEXT_PUBLIC_APPWRITE_ONESIMPLEAPI_COLLECTION_ID=onesimpleapi_integrations

# Team Membership Configuration
# IMPORTANT: Each site deployment should have its own unique TEAM_ID
# This team ID determines which Appwrite team users will be added to when they're linked to this site
# Set to 'true' to enable automatic team membership when linking users
APPWRITE_TEAM_MEMBERSHIP_ENABLED=true
# The team ID for THIS SITE - users will be added to this team when linked
# Get this from your Appwrite Console > Auth > Teams
NEXT_PUBLIC_APPWRITE_TEAM_ID=68de0080001c8d0b67a7

# Integration API Credentials
# These credentials are stored securely in environment variables, NOT in the database
# Configure these for each integration you want to use

# Cloudinary Configuration
# Get these from your Cloudinary dashboard at https://cloudinary.com/console
# Note: cloudName is stored in the database (per event), only API credentials here
CLOUDINARY_API_KEY=942572738698768
CLOUDINARY_API_SECRET=UPKAJKVDFXRY9KMcG7ZNkqgln-c

# Switchboard Canvas Configuration
# Get your API key from Switchboard Canvas dashboard
SWITCHBOARD_API_KEY=67f3d0df-5555-4a74-b8f1-e88b596b5b85

# Appwrite Transactions Configuration
# Plan tier determines transaction operation limits
# Options: FREE (100 ops), PRO (1000 ops), SCALE (2500 ops)
APPWRITE_PLAN=PRO

# Scan Logs Export Configuration
# Maximum number of records to export in a single request (prevents memory exhaustion)
# Default: 5000 records
EXPORT_MAX_RECORDS=5000