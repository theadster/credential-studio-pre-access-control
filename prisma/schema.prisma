generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  roleId    String?
  isInvited Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role? @relation(fields: [roleId], references: [id])
  logs Log[]
  invitations Invitation[]
  createdInvitations Invitation[] @relation("InvitationCreatedBy")

  @@map("users")
}

model Invitation {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator   User @relation("InvitationCreatedBy", fields: [createdBy], references: [id])

  @@map("invitations")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json     // Store permissions as JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model EventSettings {
  id                           String   @id @default(cuid())
  eventName                    String
  eventDate                    DateTime
  eventTime                    String?
  eventLocation                String
  timeZone                     String
  barcodeType                  String   // "numerical" or "alphanumerical"
  barcodeLength                Int
  barcodeUnique                Boolean
  forceFirstNameUppercase      Boolean? @default(false)
  forceLastNameUppercase       Boolean? @default(false)
  cloudinaryEnabled            Boolean? @default(false)
  cloudinaryCloudName          String?
  cloudinaryApiKey             String?
  cloudinaryApiSecret          String?
  cloudinaryUploadPreset       String?
  cloudinaryAutoOptimize       Boolean? @default(false)
  cloudinaryGenerateThumbnails Boolean? @default(false)
  cloudinaryDisableSkipCrop    Boolean? @default(false)
  cloudinaryCropAspectRatio    String?  @default("1")
  switchboardEnabled           Boolean? @default(false)
  switchboardApiEndpoint       String?
  switchboardAuthHeaderType    String?  @default("Bearer")
  switchboardApiKey            String?
  switchboardRequestBody       String?
  switchboardTemplateId        String?
  switchboardFieldMappings     Json?    // Store field mappings as JSON
  bannerImageUrl               String?
  signInBannerUrl              String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  customFields CustomField[]

  @@map("event_settings")
}

model CustomField {
  id                String   @id @default(cuid())
  eventSettingsId   String
  fieldName         String
  internalFieldName String?
  fieldType         String   // "text", "number", "date", "select", "checkbox"
  fieldOptions      Json?    // For select fields, store options as JSON
  required          Boolean  @default(false)
  order             Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  eventSettings EventSettings @relation(fields: [eventSettingsId], references: [id], onDelete: Cascade)
  attendeeCustomFieldValues AttendeeCustomFieldValue[]

  @@map("custom_fields")
}

model Attendee {
  id                    String   @id @default(cuid())
  firstName             String
  lastName              String
  barcodeNumber         String   @unique
  photoUrl              String?
  credentialUrl         String?
  credentialGeneratedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customFieldValues AttendeeCustomFieldValue[]
  logs              Log[]

  @@map("attendees")
}

model AttendeeCustomFieldValue {
  id            String @id @default(cuid())
  attendeeId    String
  customFieldId String
  value         String

  attendee    Attendee    @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([attendeeId, customFieldId])
  @@map("attendee_custom_field_values")
}

model Log {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  attendeeId String?
  action     String   // "create", "update", "delete", "view", "print"
  details    Json?    // Store additional details as JSON
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  attendee Attendee? @relation(fields: [attendeeId], references: [id])

  @@map("logs")
}

model LogSettings {
  id                    String  @id @default(cuid())
  attendeeCreate        Boolean @default(true)
  attendeeUpdate        Boolean @default(true)
  attendeeDelete        Boolean @default(true)
  attendeeView          Boolean @default(false)
  attendeeBulkDelete    Boolean @default(true)
  attendeeImport        Boolean @default(true)
  attendeeExport        Boolean @default(true)
  credentialGenerate    Boolean @default(true)
  credentialClear       Boolean @default(true)
  userCreate            Boolean @default(true)
  userUpdate            Boolean @default(true)
  userDelete            Boolean @default(true)
  userView              Boolean @default(false)
  userInvite            Boolean @default(true)
  roleCreate            Boolean @default(true)
  roleUpdate            Boolean @default(true)
  roleDelete            Boolean @default(true)
  roleView              Boolean @default(false)
  eventSettingsUpdate   Boolean @default(true)
  customFieldCreate     Boolean @default(true)
  customFieldUpdate     Boolean @default(true)
  customFieldDelete     Boolean @default(true)
  customFieldReorder    Boolean @default(true)
  authLogin             Boolean @default(true)
  authLogout            Boolean @default(true)
  logsDelete            Boolean @default(true)
  logsExport            Boolean @default(true)
  logsView              Boolean @default(false)
  systemViewEventSettings Boolean @default(false)
  systemViewAttendeeList  Boolean @default(false)
  systemViewRolesList     Boolean @default(false)
  systemViewUsersList     Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("log_settings")
}
