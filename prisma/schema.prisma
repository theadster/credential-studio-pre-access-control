generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  roleId    String?
  isInvited Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role Role? @relation(fields: [roleId], references: [id])
  logs Log[]
  invitations Invitation[]
  createdInvitations Invitation[] @relation("InvitationCreatedBy")

  @@map("users")
}

model Invitation {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator   User @relation("InvitationCreatedBy", fields: [createdBy], references: [id])

  @@map("invitations")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json     // Store permissions as JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

model EventSettings {
  id                    String   @id @default(cuid())
  eventName             String
  eventDate             DateTime
  eventTime             String?
  eventLocation         String
  timeZone              String
  barcodeType           String   // "numerical" or "alphanumerical"
  barcodeLength         Int
  barcodeUnique         Boolean
  cloudinaryCloudName   String?
  cloudinaryApiKey      String?
  cloudinaryApiSecret   String?
  cloudinaryUploadPreset String?
  switchboardApiKey     String?
  switchboardTemplateId String?
  bannerImageUrl        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customFields CustomField[]

  @@map("event_settings")
}

model CustomField {
  id              String   @id @default(cuid())
  eventSettingsId String
  fieldName       String
  fieldType       String   // "text", "number", "date", "select", "checkbox"
  fieldOptions    Json?    // For select fields, store options as JSON
  required        Boolean  @default(false)
  order           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  eventSettings EventSettings @relation(fields: [eventSettingsId], references: [id], onDelete: Cascade)
  attendeeCustomFieldValues AttendeeCustomFieldValue[]

  @@map("custom_fields")
}

model Attendee {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  barcodeNumber String   @unique
  photoUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customFieldValues AttendeeCustomFieldValue[]
  logs              Log[]

  @@map("attendees")
}

model AttendeeCustomFieldValue {
  id            String @id @default(cuid())
  attendeeId    String
  customFieldId String
  value         String

  attendee    Attendee    @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([attendeeId, customFieldId])
  @@map("attendee_custom_field_values")
}

model Log {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  attendeeId String?
  action     String   // "create", "update", "delete", "view", "print"
  details    Json?    // Store additional details as JSON
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  attendee Attendee? @relation(fields: [attendeeId], references: [id])

  @@map("logs")
}
