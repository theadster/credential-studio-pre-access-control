# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Verification Configuration
# URL where users will be redirected to complete email verification
NEXT_PUBLIC_VERIFICATION_URL=http://localhost:3000/verify-email

# Password Reset Configuration
# URL where users will be redirected to reset their password
NEXT_PUBLIC_PASSWORD_RESET_URL=http://localhost:3000/reset-password

# Appwrite Configuration
# Get these from your Appwrite project at https://cloud.appwrite.io
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here

# Session Cookie Configuration (optional)
# Name of the session cookie used for web client authentication
# Default: 'appwrite-session'
# APPWRITE_SESSION_COOKIE_NAME=appwrite-session

# Appwrite Database IDs (generated by setup-appwrite.ts script)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=credentialstudio
NEXT_PUBLIC_APPWRITE_USERS_TABLE_ID=users
NEXT_PUBLIC_APPWRITE_ROLES_TABLE_ID=roles
NEXT_PUBLIC_APPWRITE_ATTENDEES_TABLE_ID=attendees
NEXT_PUBLIC_APPWRITE_CUSTOM_FIELDS_TABLE_ID=custom_fields
NEXT_PUBLIC_APPWRITE_EVENT_SETTINGS_TABLE_ID=event_settings
NEXT_PUBLIC_APPWRITE_LOGS_TABLE_ID=logs
NEXT_PUBLIC_APPWRITE_LOG_SETTINGS_TABLE_ID=log_settings
NEXT_PUBLIC_APPWRITE_REPORTS_TABLE_ID=reports

# Mobile Access Control Tables
NEXT_PUBLIC_APPWRITE_ACCESS_CONTROL_TABLE_ID=access_control
NEXT_PUBLIC_APPWRITE_APPROVAL_PROFILES_TABLE_ID=approval_profiles
NEXT_PUBLIC_APPWRITE_SCAN_LOGS_TABLE_ID=scan_logs

# Access Control Feature Flag
# Set to 'true' to enable the Access Control feature globally
# When disabled, the Access Control tab and all related functionality will be hidden
# Default: false (disabled)
NEXT_PUBLIC_ENABLE_ACCESS_CONTROL=false

# Integration Tables
NEXT_PUBLIC_APPWRITE_CLOUDINARY_TABLE_ID=cloudinary_integrations
NEXT_PUBLIC_APPWRITE_SWITCHBOARD_TABLE_ID=switchboard_integrations
NEXT_PUBLIC_APPWRITE_ONESIMPLEAPI_TABLE_ID=onesimpleapi_integrations

# Async PDF Generation
NEXT_PUBLIC_APPWRITE_PDF_JOBS_TABLE_ID=pdf_jobs
NEXT_PUBLIC_APPWRITE_PDF_WORKER_FUNCTION_ID=your_pdf_worker_function_id_here

# PDF Worker Appwrite Function Environment Variables
# These are configured in the Appwrite Console under your Function's settings,
# NOT in .env.local. Set the following variables on the function itself:
#
#   APPWRITE_ENDPOINT        - Your Appwrite API endpoint (e.g. https://nyc.cloud.appwrite.io/v1)
#   APPWRITE_PROJECT_ID      - Your Appwrite project ID
#   APPWRITE_API_KEY         - Server-side API key with database read/write permissions
#   DATABASE_ID              - Appwrite database ID (e.g. credentialstudio)
#   ATTENDEES_TABLE_ID       - Table ID for attendees
#   EVENT_SETTINGS_TABLE_ID  - Table ID for event settings
#   ONESIMPLEAPI_TABLE_ID    - Table ID for OneSimpleAPI integrations
#   CUSTOM_FIELDS_TABLE_ID   - Table ID for custom fields
#   PDF_JOBS_TABLE_ID        - Table ID for pdf_jobs (matches NEXT_PUBLIC_APPWRITE_PDF_JOBS_TABLE_ID)
#   SITE_URL                 - Public URL of the site (used to absolutize relative asset URLs)

# Team Membership Configuration
# IMPORTANT: Each site deployment should have its own unique TEAM_ID
# This team ID determines which Appwrite team users will be added to when they're linked to this site
# Set to 'true' to enable automatic team membership when linking users
APPWRITE_TEAM_MEMBERSHIP_ENABLED=true
# The team ID for THIS SITE - users will be added to this team when linked
# Get this from your Appwrite Console > Auth > Teams
NEXT_PUBLIC_APPWRITE_TEAM_ID=your_team_id_here

# Integration API Credentials
# These credentials are stored securely in environment variables, NOT in the database
# Configure these for each integration you want to use

# Cloudinary Configuration
# Get these from your Cloudinary dashboard at https://cloudinary.com/console
# Note: cloudName is stored in the database (per event), only API credentials here
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Switchboard Canvas Configuration
# Get your API key from Switchboard Canvas dashboard
SWITCHBOARD_API_KEY=your_switchboard_api_key

# Appwrite Transactions Configuration
# Plan tier determines transaction operation limits
# Options: FREE (100 ops), PRO (1000 ops), SCALE (2500 ops)
APPWRITE_PLAN=PRO

# Scan Logs Export Configuration
# Maximum number of records to export in a single request (prevents memory exhaustion)
# Default: 5000 records
EXPORT_MAX_RECORDS=5000
